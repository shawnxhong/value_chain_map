# Copy to infra/.env. Docker Compose substitutes these at `docker compose up`.

# Anthropic auth — passed through to the backend container.
# Leave blank to rely on an `ant` profile mounted into the container instead
# (the SDK resolves ANTHROPIC_API_KEY or an ant profile at call time).
ANTHROPIC_API_KEY=

# Optional model-id overrides (defaults shown; see backend/vcm/config.py):
# VCM_EXTRACT_MODEL=claude-sonnet-4-6
# VCM_VERIFY_MODEL=claude-opus-4-8
